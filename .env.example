# ═══════════════════════════════════════════════════════════
# IEE KPI API + Dashboard v5.0 — Environment Variables
# ═══════════════════════════════════════════════════════════
# Set these in Railway's Variables tab. Never commit actual values.

# ── MongoDB Atlas ────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────
API_KEY=your-master-api-key
# JWT_SECRET is REQUIRED — server fails to start if unset.
# Generate once with: openssl rand -hex 32 — keep stable across deploys
# or every restart will invalidate every issued session token.
JWT_SECRET=generate-with-openssl-rand-hex-32

# ── AI Chatbot ───────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-your-claude-api-key

# ── SendGrid Email ───────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key
SENDGRID_TEMPLATE_ID=d-your-ops-report-template-id
SENDGRID_INVITE_TEMPLATE_ID=d-your-invite-template-id
SENDGRID_FROM_EMAIL=ops@myiee.org

# ── Railway (auto-provided) ─────────────────────────────
# PORT=3000
NODE_ENV=production

# ═══════════════════════════════════════════════════════════
# ARCHITECTURE — Single Railway Service
# ═══════════════════════════════════════════════════════════
# Express serves API + React dashboard from /dist
# Build: npm install → postinstall builds client → npm start
#
# MongoDB databases:
#   orders           — V2 order data (orderStatusHistory, order-discussion)
#   user             — V2 staff data
#   iee_dashboard    — All dashboard config:
#     dashboard_users            — Dashboard login accounts
#     dashboard_benchmarks       — XpH targets
#     dashboard_production_hours — Net hours per level
#     dashboard_user_levels      — Staff L0-L5 assignments
#     dashboard_ai_prompts       — System prompt versions
#     dashboard_ai_guardrails    — AI safety config
#     dashboard_glossary         — Terminology for AI context
#     dashboard_email_schedules  — SendGrid email schedules
#     dashboard_chat_history     — AI chat logs
#     dashboard_audit_log        — All config changes
#
# First deploy: POST /auth/setup to create admin account
# ═══════════════════════════════════════════════════════════
